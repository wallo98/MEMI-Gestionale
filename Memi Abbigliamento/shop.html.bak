    </main>
  </div><!-- /shop-layout -->

  <script>
    // Mobile filter drawer
    const filterDrawer = document.getElementById('filterDrawer');
    document.getElementById('mobileFilterBtn').addEventListener('click', () => {
      filterDrawer.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
    function closeFilterDrawer() {
      filterDrawer.classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('filterScrim').addEventListener('click', closeFilterDrawer);
    document.getElementById('filterClose').addEventListener('click', closeFilterDrawer);

    // ── FILTER ENGINE ───────────────────────────────────────────────────────
    var PRICE_MAX = 300;
    var activeCategorie = new Set();
    var activeTaglie    = new Set();
    var activeColori    = new Set();
    var activePrezzo    = PRICE_MAX;
    var X_SVG = '<svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    var coloreLabel = {
      blush:'Rosa cipria',salvia:'Salvia',lavanda:'Lavanda',
      avorio:'Avorio',menta:'Menta',antico:'Rosa antico',espresso:'Espresso'
    };

    function applyFilters() {
      var cards = document.querySelectorAll('#productGrid .product-card');
      var visible = 0;
      cards.forEach(function(card) {
        var cat    = card.dataset.categoria;
        var taglie = card.dataset.taglie ? card.dataset.taglie.split(' ') : [];
        var colore = card.dataset.colore;
        var prezzo = parseInt(card.dataset.prezzo, 10);
        var okCat    = activeCategorie.size === 0 || activeCategorie.has(cat);
        var okSize   = activeTaglie.size    === 0 || taglie.some(function(t){ return activeTaglie.has(t); });
        var okColore = activeColori.size    === 0 || activeColori.has(colore);
        var okPrezzo = prezzo <= activePrezzo;
        var show = okCat && okSize && okColore && okPrezzo;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      var countEl = document.querySelector('.results-count strong');
      if (countEl) countEl.textContent = visible;
      renderChips();
      syncURL();
    }

    // ── Zalando-style URL sync ─────────────────────────────────
    var CATEGORY_URL_MAP = {
      novita: 'novita', accessori: 'accessori', vestiti: 'vestiti',
      top: 'top', pantaloni: 'pantaloni', gonne: 'gonne', blazer: 'blazer', set: 'set'
    };
    var CATEGORY_LABEL_MAP = {
      novita: 'Novità', accessori: 'Accessori', vestiti: 'Vestiti',
      top: 'Top & Bluse', pantaloni: 'Pantaloni', gonne: 'Gonne', blazer: 'Blazer', set: 'Set Coordinati'
    };

    function syncURL() {
      var params = new URLSearchParams();
      if (activeCategorie.size === 1) {
        var cat = Array.from(activeCategorie)[0];
        params.set('categoria', cat);
      } else if (activeCategorie.size > 1) {
        params.set('categoria', Array.from(activeCategorie).join(','));
      }
      if (activeTaglie.size > 0) params.set('taglie', Array.from(activeTaglie).join(','));
      if (activeColori.size > 0) params.set('colori', Array.from(activeColori).join(','));
      if (activePrezzo < PRICE_MAX) params.set('prezzo', activePrezzo);
      var qs = params.toString();
      var url = 'shop.html' + (qs ? '?' + qs : '');
      try { history.pushState({ memi: true, qs: qs }, '', url); } catch(e) {}

      // Update <title> and hero eyebrow live
      var cat = params.get('categoria');
      var label = cat ? (CATEGORY_LABEL_MAP[cat] || cat) : 'Abbigliamento';
      document.title = label + ' · Memi Abbigliamento';
      var heroTitle = document.querySelector('.page-hero-title');
      if (heroTitle && cat && !document.documentElement.classList.contains('filtering')) {
        heroTitle.innerHTML = CATEGORY_LABEL_MAP[cat]
          ? CATEGORY_LABEL_MAP[cat].split(' ').map(function(w,i){ return i===0 ? w : '<em>'+w+'</em>'; }).join(' ')
          : label;
      }

      // Sync cat-nav active state
      document.querySelectorAll('.nav-link').forEach(function(a) {
        var u = new URL(a.href, location.href);
        var ac = u.searchParams.get('categoria');
        var as = u.searchParams.get('saldi');
        var match = (!cat && !ac && !as) ||
                    (cat && ac === cat) ||
                    (params.get('saldi') === '1' && as === '1');
        a.classList.toggle('active', match);
      });
    }

    // Restore filters from URL on popstate (back/forward navigation)
    window.addEventListener('popstate', function(e) {
      var params = new URLSearchParams(window.location.search);
      activeCategorie.clear()