# ── Database ──────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=memi_user
DB_PASSWORD=changeme_strong_password
DB_NAME=memi_db

# ── JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_hex_secret_for_customers
JWT_ADMIN_SECRET=replace_with_different_64_char_hex_secret_for_admins
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS: comma-separated list of allowed frontend origins ────
ALLOWED_ORIGINS=https://memi.it,https://admin.memi.it

# ── Stripe (get keys from https://dashboard.stripe.com/apikeys) ──────────────
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me

# ── Frontend URL (used in emails for reset-password links) ────────────────
FRONTEND_URL=https://memiabbigliamento.it

# ── Admin bootstrap (READ AT STARTUP) ──────────────────────────────────────
# If BOTH ADMIN_EMAIL and ADMIN_PASSWORD are set, the backend upserts this admin
# account with a freshly hashed password every boot (src/db/migrations.js →
# bootstrapAdmin). This is the supported way to set/rotate the admin login.
#
# schema.sql still seeds a default admin (admin@memi.it / "memi2026admin") on a
# brand-new database. If that default is still present in production, the backend
# logs a red SECURITY warning at startup until you rotate it. Set the two vars
# below to a strong password BEFORE going live.
ADMIN_EMAIL=admin@memi.it
ADMIN_PASSWORD=CHANGE_ME_to_a_strong_password
